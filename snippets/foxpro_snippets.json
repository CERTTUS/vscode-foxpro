{
	"NEWOBJECT — novo objeto": {
		"prefix": "newo",
		"body": [ 
			"LOCAL ${1:loInstancia}",
			"$1 = NEWOBJECT('${2:NomeClasse}','${3:ArquivoClasse}',''$0)"
		],
		"description": "Macro NEWOBJECT (criar instância de classe)"
	},

	"ADDPROPERTY — adicionar propriedade": {
		"prefix": "adp",
		"body": "ADDPROPERTY(${1:loDados},'${2:NomePropriedade}',${3:lcValor})",
		"description": "Macro ADDPROPERTY (adicionar propriedade)"
	},

	"BINDEVENT — associar evento": {
		"prefix": "bnd",
		"body": "BINDEVENT(${1:loFonteEvento},'${2:NomeEvento}',${3:loTratador},'${4:NomeMetodo}')",
		"description": "Macro BINDEVENT (associar evento)"
	},

	"Instanciação de objeto EMPTY": {
		"prefix": "eo",
		"body": [
			"LOCAL ${1:loDados}",
			"$1 = CREATEOBJECT('EMPTY')"
		],
		"description": "Cria uma instância de EMPTY"
	},

	"Bloco try/catch": {
		"prefix": "tryc",
		"body": [
			"TRY",
			"\t$0",
			"CATCH TO ${1:loExcecao}",
			"\t",
			"ENDTRY"
		],
		"description": "Bloco TRY/CATCH com exceção em objeto"
	},

	"Bloco try/catch/finally": {
		"prefix": "tryf",
		"body": [
			"TRY",
			"\t$0",
			"CATCH TO ${1:loExcecao}",
			"\t",
			"FINALLY",
			"\t",
			"ENDTRY"
		],
		"description": "Bloco TRY/CATCH/FINALLY com exceção em objeto"
	},

	"IF / ELSE / ENDIF": {
		"prefix": "ifel",
		"body": [
			"IF ${1:condicao}",
			"\t$0",
			"ELSE",
			"\t",
			"ENDIF"
		],
		"description": "Bloco simples IF, ELSE e ENDIF"
	},

	"IF / ENDIF": {
		"prefix": "ifend",
		"body": [
			"IF ${1:condicao}",
			"\t$0",
			"ENDIF"
		],
		"description": "Bloco simples IF e ENDIF"
	},

	"Expressão IIF": {
		"prefix": "iifs",
		"body": [
			"IIF(${1:condicao},${2:seVerdadeiro},${3:seFalso})"
		],
		"description": "Função IIF (se condição, valor se verdadeiro, senão)"
	},

	"FOR / ENDFOR": {
		"prefix": "fore",
		"body": [
			"LOCAL ${1:lnPasso}",
			"FOR $1 = ${2:1} TO ${3:lnPassosMax}",
			"\t$0",
			"ENDFOR"
		],
		"description": "Laço FOR simples até ENDFOR"
	},

	"ALINES() com laço FOR": {
		"prefix": "foralines",
		"body": [
			"LOCAL lnStep,lnCount,laLines[1],lcLine",
			"lnCount = ALINES(laLines,${1:lcTexto})",
			"FOR m.lnStep = 1 TO m.lnCount",
			"\tlcLine = laLines[m.lnStep]",
			"\t$0",
			"ENDFOR"
		],
		"description": "Divide a string em array e percorre com FOR"
	},

	"Expressão ICASE": {
		"prefix": "ics",
		"body": [
			"ICASE(${1:condicao1},${2:valorSe1},${3:condicao2},${4:valorSe2},${5:casoContrario})"
		],
		"description": "Função ICASE (cascata de condições)"
	},

	"SELECT local (restaurar área)": {
		"prefix": "lnsel",
		"body": [
			"LOCAL lnOldSel",
			"lnOldSel = SELECT()",
			"$0",
			"SELECT (lnOldSel)"
		],
		"description": "Guarda a área de trabalho atual e restaura ao final"
	},

	"DO CASE / ENDCASE": {
		"prefix": "docase",
		"body": [
			"DO CASE",
			"\tCASE ${1:condicao}",
			"\t\t",
			"\tCASE ${2:condicao2}",
			"\t\t",
			"\tOTHER",
			"\t\t",
			"ENDCASE"
		],
		"description": "Estrutura DO CASE com CASE, OTHER e ENDCASE"
	},

	"Procedimento": {
		"prefix": "prc",
		"body": [
            "* ${3:DescricaoProcedimento}",
			"PROCEDURE ${1:NomeProcedimento} ($2)",
			"\t$0",
			"ENDPROC"
		],
		"description": "Procedimento FoxPro simples (PROCEDURE … ENDPROC)"
	},

    // [interno]
	"fSelectStatement — consulta (interno)": {
		"prefix": "fs",
		"body": [
			"WITH fSelectStatement('${1:Arquivo}')",
			"\t$0",
			"ENDWITH"
		],
		"description": "fSelectStatement simples (interno)"
	},

    // [interno]
	"fChooserDao — seletor (interno)": {
		"prefix": "fchooser",
		"body": [
            "LOCAL loChooser,loResult",
            "loChooser = fChooserDao()",
			"WITH loChooser.OpenChooser('${1:Arquivo}')",
			"\t.Where('${2:NomeCampo}',${3:lcValor})$0",
            "ENDWITH",
            "loResult = loChooser.Show('${4:TituloDialogo}')",
            "IF VARTYPE(loResult)#'O'",
            "\tRETURN .f.",
            "ENDIF"
		],
		"description": "Modelo para montar consulta e exibir diálogo chooser (interno)"
	},

    // [interno]
	"fSelectStatement.IntoObject (interno)": {
		"prefix": "fso",
		"body": [
			"WITH fSelectStatement('${1:Arquivo}')",
			"\t$0",
			"\t${2:loDados} = .IntObject()",
			"ENDWITH"
		],
		"description": "fSelectStatement com saída em objeto de dados (interno)"
	},

    // [interno]
	"fSelectStatement.IntoValue (interno)": {
		"prefix": "fsv",
		"body": [
			"WITH fSelectStatement('${1:Arquivo}')",
			"\t.Fields('${2:Campo}')",
			"\t$0",
			"\t${3:lcValor} = .IntoValue()",
			"ENDWITH"
		],
		"description": "fSelectStatement com valor escalar de saída (interno)"
	},

    // [interno]
	"fStoredProcedure (interno)": {
		"prefix": "fsp",
		"body": [
			"WITH fStoredProcedure('${1:nomeSp}')",
			"\t.Params(${2:Parametros})",
			"\t.Execute()",
			"ENDWITH"
		],
		"description": "fStoredProcedure simples (interno)"
	},

    // [interno]
	"fUpdateStatement (interno)": {
		"prefix": "fup",
		"body": [
			"WITH fUpdateStatement('${1:Arquivo}')",
			"\t.Set('${2:Campo1}',${3:lcValor1})",
			"\t.Where('${4:Campo2}',${5:lcValor2})",
			"\t$0",
			"\t.Execute()",
			"ENDWITH"
		],
		"description": "fUpdateStatement simples (interno)"
	},

    // [interno]
	"fInsertStatement (interno)": {
		"prefix": "fin",
		"body": [
			"WITH fInsertStatement('${1:arquivo}')",
			"\t.Set('${2:campo}',${3:lcValor})",
			"\t$0",
			"\t.Execute()",
			"ENDWITH"
		],
		"description": "fInsertStatement simples (interno)"
	},

    // [interno]
	"fDeleteStatement (interno)": {
		"prefix": "fdel",
		"body": [
			"WITH fDeleteStatement('${1:arquivo}')",
			"\t.Where('${2:campo}',${3:lcValor})",
			"\t.Execute()",
			"ENDWITH"
		],
		"description": "fDeleteStatement simples (interno)"
	},

	"DEFINE CLASS": {
		"prefix": "dc",
		"body": [
			"DEFINE CLASS ${1:NomeClasse} AS ${2:ClassePai}",
			"\t$3",
			"\tPROCEDURE ${4:Init} ()",
			"\t\t$0",
			"\tENDPROC",
			"ENDDEFINE"
		],
		"description": "DEFINE CLASS sem referência a arquivo externo"
	},

	"DEFINE CLASS … OF": {
		"prefix": "dco",
		"body": [
			"DEFINE CLASS ${1:NomeClasse} AS ${2:ClassePai} OF ${2}.fxp",
			"",
			"\tPROCEDURE ${3:Init} ()",
			"\t\t$0",
			"\tENDPROC",
			"ENDDEFINE"
		],
		"description": "DEFINE CLASS com referência a arquivo .fxp"
	},

	"Classe instanciável (arquivo objeto)": {
		"prefix": "dcf",
		"body": [
			"PROCEDURE ${TM_FILENAME_BASE} (${3:tcParametro})",
			"\tRETURN CREATEOBJECT('${1}',${3})",
			"ENDPROC",
			"",
			"DEFINE CLASS ${1:${TM_FILENAME_BASE}} AS ${2:ClassePai} OF ${2}.fxp",
			"\t$4",
			"\tPROCEDURE Init (${3})",
			"\t\t$0",
			"\tENDPROC",
			"ENDDEFINE"
		],
		"description":"DEFINE CLASS com função fábrica para instanciar"
	},
 
    // [interno]
	"Classe StoredProcedure (interno)": {
		"prefix": "dcsp",
		"body": [
			"DEFINE CLASS ${1:nomeSpStoredProc} AS StoredProcedure OF StoredProcedure.fxp",
			"\t$4",
			"\t",
			"\tPROCEDURE Run ()",
			"\t\t$0",
			"\tENDPROC",
			"ENDDEFINE"
		],
		"description":"DEFINE CLASS para stored procedure (interno)"
	},

    // multiprompt (vários prompts)
    // [interno]
    "Definição Multiprompt": {
        "prefix": "multi",
        "body": [
			"LOCAL ${1:lcCampos},${2:loResultado}",
			"$1 = ''",
            "TEXT TO $1 ADDITIVE TEXTMERGE NOSHOW FLAGS 3 PRETEXT 3",
            "\t$0",
            "ENDTEXT",
            "$2 = MultiPrompt($1,${3:'Titulo do dialogo'})",
            "",
            "IF VARTYPE(${2})#'O'",
            "\tRETURN .f.",
            "ENDIF"
        ],
        "description":"Definição de diálogo Multiprompt (interno)"
    },

    "Campo de texto Multiprompt": {
        "prefix": "mptext",
        // Exemplo: produto com valor inicial e validação condicional no multiprompt
        "body": "${1:NomeCampoTexto} ~C ${2:Legenda} ~E <<${3:pcValorInicial}>> ~V ${4:EventoValidar(@{1})}",
        "description": "Campo de texto genérico no Multiprompt (interno)"
    },

    "Nome de texto Multiprompt": {
        "prefix": "mpname",
        "body": "${1:NomeTexto} ~C ${2:Legenda} ~EC <<${3:pcValorInicial}>>",
        "description": "Campo de texto permitindo letras minúsculas (interno)"
    },

    "Campo numérico Multiprompt": {
        "prefix": "mpnum",
        "body": "${1:NomeNumero} ~C ${2:Legenda} ~EN <<${3:pnValorInicial}>> ~F R ~M ${4:999,999.99}",
        "description": "Campo numérico no Multiprompt (interno)"
    },

    "Campo de data Multiprompt": {
        "prefix": "mpdate",
        "body": "${1:NomeData} ~C ${2:Legenda} ~ED <<${3:pdValorInicial}>>",
        "description": "Campo de data no Multiprompt (interno)"
    },

    "Campo lista Multiprompt": {
        "prefix": "mplist",
        "body": "${1:NomeLista} ~C ${2:Legenda} ~EC <<${3:pcValorInicial}>> ~T LIST ~L ${4:Elemento 1,Elemento 2}",
        "description": "Lista suspensa genérica no Multiprompt (interno)"
    },

    "Caixa de seleção Multiprompt": {
        "prefix": "mpcheck",
        "body": "${1:NomeCheck} ~C ${2:Legenda} ~EL <<${3:pbValorInicial}>> ~T Check",
        "description": "Caixa de seleção genérica no Multiprompt (interno)"
    },
    "Grupo Multiprompt": {
        "prefix": "mpgroup",
        // Exemplo: grupo com layout vertical/horizontal no multiprompt
        "body": "${1:NomeGrupo} ~T Group ~F Layout ~S${2|V,H|} 10",
        "description": "Grupo de campos no Multiprompt (interno)"
    },

    "Rótulo Multiprompt": {
        "prefix": "mplabel",
        // Exemplo: rótulo com conteúdo dinâmico e grupo no multiprompt
        "body": "${1:NomeRotulo} ~T LABEL ~C ${2:Legenda} ~EC <<${3:lcTextoRotulo}>> ~B FIXED,10,N",
        "description": "Rótulo (label) genérico no Multiprompt (interno)"
    },

    "Intervalo Multiprompt": {
        "prefix": "mprange",
        // Exemplo: intervalo (mínimo||máximo) com validação e grupo no multiprompt
        "body": "${1:NomeIntervalo} ~T RANGE ~C ${2:RotuloDe} ~E <<${3:lcInicioIntervalo}>>||<<${4:lcFimIntervalo}>>",
        "description": "Campo de intervalo (dois valores) no Multiprompt (interno)"
    },

    "Campo memo Multiprompt": {
		"prefix": "mpnote",
		// Exemplo: campo memo (~T Memo) no multiprompt
		"body": "${1:NomeMemo} ~T EDIT ~C ${2:Legenda} ~@C <<${3:pcTextoMemo}>>",
		"description": "Campo memo genérico no Multiprompt (interno)"
	},

	// auxiliares DAO
	// [interno]
    "DataAccessObject.Open (interno)": {
		"prefix": "dopen",
		"body": [
			"WITH this.Open('${1:Arquivo}')",
			"\t$0",
			"ENDWITH"
		],
		"description": "Open genérico em instância DataAccessObject (interno)"
	},

    "this.Dao.Open (interno)": {
		"prefix": "popen",
		"body": [
			"WITH this.${1:NomeDao}.Open('${2:Arquivo}')",
			"\t$0",
			"ENDWITH"
		],
		"description": "Open genérico na propriedade Dao (interno)"
	},

	"dal.Where completo (interno)": {
		"prefix": "dwcomplete",
		// Exemplo: campo memo (~T Memo) no multiprompt
		"body": ".Where('${1:Campo}',${2:lcValorTeste},.f.,'${3:AliasTabela}')",
		"description": "Cláusula .Where completa com alias de tabela (DAL/DAO) (interno)"
	},

	"dal.Where simples (interno)": {
		"prefix": "dw",
		// Exemplo: campo memo (~T Memo) no multiprompt
		"body": ".Where('${1:Campo}',${2:lcValorTeste})",
		"description": "Cláusula .Where básica (DAL/DAO) (interno)"
	},

	"dal.WhereEmptyString (interno)": {
		"prefix": "dwempty",
		// Exemplo: campo memo (~T Memo) no multiprompt
		"body": ".WhereEmptyString('${1:Campo}','${2:AliasTabela}')",
		"description": "Cláusula .WhereEmptyString (DAL/DAO) (interno)"
	},

	"dal.WhereTrue (interno)": {
		"prefix": "dwtrue",
		// Exemplo: campo memo (~T Memo) no multiprompt
		"body": ".WhereTrue('${1:Campo}','${2:AliasTabela}')",
		"description": "Cláusula .WhereTrue (DAL/DAO) (interno)"
	},

	"dal.WhereFalse (interno)": {
		"prefix": "dwfalse",
		// Exemplo: campo memo (~T Memo) no multiprompt
		"body": ".WhereFalse('${1:Campo}','${2:AliasTabela}')",
		"description": "Cláusula .WhereFalse (DAL/DAO) (interno)"
	},

	"dal.WhereInList_Iterable (interno)": {
		"prefix": "dwiterable",
		"body": [
			"WITH .WhereInList_Iterable('${1:Campo}','${2:Tabela}')",
			"\tSELECT (${3:AliasCursor})",
			"\tSCAN",
			"\t\t.Iterate(${4:CampoCursor})",
			"\tENDSCAN",
			"\t.CompleteIterable()",
			"ENDWITH",
		],
		"description": "WhereInList_Iterable (DAL/DAO) (interno)"
	},

	"dal.Join (interno)": {
		"prefix": "djoin",
		"body": [
			".Join('${1:Arquivo}')",
			"\t.JoinOn('${2:Campo}')"
		],
		"description": "JOIN básico (DAL/DAO) (interno)"
	},

	"dal.Fields (interno)": {
		"prefix": "dfields",
		// Exemplo: campo memo (~T Memo) no multiprompt
		"body": ".Fields('${1:Campo1,Campo2,Campo3}','${2:AliasTabela}')",
		"description": "Lista de campos no SELECT (DAL/DAO) (interno)"
	},	

	"dal.Set (interno)": {
		"prefix": "dset",
		// Exemplo: campo memo (~T Memo) no multiprompt
		"body": ".Set('${1:Campo}',${2:lcValor})",
		"description": ".Set em INSERT/UPDATE (DAL/DAO) (interno)"
	},

	"dal.SetObject (interno)": {
		"prefix": "dsetobject",
		// Exemplo: campo memo (~T Memo) no multiprompt
		"body": ".SetObject(${1:loDados},'${2:Incluir1,Incluir2,Incluir3}','${3:Excluir1,tcExcluir2,Excluir3}')",
		"description": ".SetObject em INSERT/UPDATE (DAL/DAO) (interno)"
	},

	"dal.IntoObject (interno)": {
		"prefix": "dinobject",
		// Exemplo: campo memo (~T Memo) no multiprompt
		"body": "${1:loDados} = .IntoObject($2)",
		"description": ".IntoObject — resultado como objeto (interno)"
	},	

	"dal.IntoValue (interno)": {
		"prefix": "dinvalue",
		// Exemplo: campo memo (~T Memo) no multiprompt
		"body": "${1:lcValor} = .IntoValue($2)",
		"description": ".IntoValue — resultado como valor escalar (interno)"
	},	

	"dal.IntoCursor (interno)": {
		"prefix": "dincursor",
		// Exemplo: campo memo (~T Memo) no multiprompt
		"body": ".IntoCursor('${1:CursorTemp}')",
		"description": ".IntoCursor — resultado como cursor temporário FoxPro (interno)"
	},	
}
